amends "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Builtins.pkl"

local prePushBranchCheck = """
repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"
[ -d apps/mac ] || exit 0
if ! awk 'NF && $1 !~ /^refs\\/tags\\// && $3 !~ /^refs\\/tags\\// { found = 1 } END { exit found ? 0 : 1 }'; then
  exit 0
fi
"""

hooks {
  ["pre-commit"] {
    steps {
      ["check-added-large-files"] = (Builtins.check_added_large_files) {
        check = "hk util check-added-large-files --maxkb 2048 {{ files }}"
      }
      ["check-case-conflict"] = Builtins.check_case_conflict
      ["check-merge-conflict"] = Builtins.check_merge_conflict
      ["detect-private-key"] = Builtins.detect_private_key
      ["web-staged"] {
        glob = "**"
        dir = "apps/supaterm.com"
        check = "vp staged"
        depends = "check-added-large-files"
      }
      ["swiftlint"] {
        glob = List("**/*.swift", ".swiftlint.yml")
        dir = "apps/mac"
        check = "make lint"
        depends = "check-added-large-files"
      }
    }
  }
  ["pre-push"] {
    steps {
      ["git-lfs"] {
        check = "git lfs pre-push {{ hook_args }}"
        stdin = "{{ hook_stdin }}"
      }
      ["validate-release-tags"] {
        check = """
          repo_root=$(git rev-parse --show-toplevel)
          cd "$repo_root"
          [ ! -d apps/mac ] || python3 .github/scripts/bump_and_release.py validate-pre-push
          """
        stdin = "{{ hook_stdin }}"
        depends = "git-lfs"
      }
      ["web-install"] {
        check = "\(prePushBranchCheck)\nmake web-install"
        stdin = "{{ hook_stdin }}"
        depends = "validate-release-tags"
      }
      ["web-check"] {
        check = "\(prePushBranchCheck)\nmake web-check"
        stdin = "{{ hook_stdin }}"
        depends = "web-install"
      }
      ["web-test"] {
        check = "\(prePushBranchCheck)\nmake web-test"
        stdin = "{{ hook_stdin }}"
        depends = "web-install"
      }
      ["docs-install"] {
        check = "\(prePushBranchCheck)\nmake docs-install"
        stdin = "{{ hook_stdin }}"
        depends = "validate-release-tags"
      }
      ["docs-check"] {
        check = "\(prePushBranchCheck)\nmake docs-check"
        stdin = "{{ hook_stdin }}"
        depends = "docs-install"
      }
      ["docs-validate"] {
        check = "\(prePushBranchCheck)\nmake docs-validate"
        stdin = "{{ hook_stdin }}"
        depends = "docs-check"
      }
      ["docs-build"] {
        check = "\(prePushBranchCheck)\nmake docs-build"
        stdin = "{{ hook_stdin }}"
        depends = "docs-validate"
      }
      ["mac-scan-dead-code"] {
        check = "\(prePushBranchCheck)\nmake mac-scan-dead-code"
        stdin = "{{ hook_stdin }}"
        depends = "validate-release-tags"
      }
      ["mac-test"] {
        check = "\(prePushBranchCheck)\nmake mac-test"
        stdin = "{{ hook_stdin }}"
        depends = "mac-scan-dead-code"
      }
    }
  }
  ["post-checkout"] {
    steps {
      ["git-lfs"] {
        check = "git lfs post-checkout {{ hook_args }}"
      }
    }
  }
  ["post-merge"] {
    steps {
      ["git-lfs"] {
        check = "git lfs post-merge {{ hook_args }}"
      }
    }
  }
  ["post-commit"] {
    steps {
      ["git-lfs"] {
        check = "git lfs post-commit {{ hook_args }}"
      }
    }
  }
}
