amends "package://github.com/jdx/hk/releases/download/v1.44.2/hk@1.44.2#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.44.2/hk@1.44.2#/Builtins.pkl"

hooks {
  ["pre-commit"] {
    steps {
      ["check-added-large-files"] = (Builtins.check_added_large_files) {
        check = "hk util check-added-large-files --maxkb 2048 {{ files }}"
      }
      ["check-case-conflict"] = Builtins.check_case_conflict
      ["check-merge-conflict"] = Builtins.check_merge_conflict
      ["detect-private-key"] = Builtins.detect_private_key
      ["web-staged"] {
        glob = "**"
        dir = "apps/supaterm.com"
        check = "vp staged"
        depends = "check-added-large-files"
      }
      ["swiftlint"] = (Builtins.swiftlint) {
        glob = List("**/*.swift", ".swiftlint.yml")
        dir = "apps/mac"
        check = "make lint"
        fix = null
        depends = "check-added-large-files"
      }
    }
  }
  ["pre-push"] {
    steps {
      ["git-lfs"] {
        check = "git lfs pre-push {{ hook_args }}"
        stdin = "{{ hook_stdin }}"
      }
      ["validate-release-tags"] {
        check = "python3 .github/scripts/bump_and_release.py validate-pre-push"
        stdin = "{{ hook_stdin }}"
        depends = "git-lfs"
      }
      ["branch-checks"] {
        check = "python3 .github/scripts/bump_and_release.py run-pre-push-branch-checks"
        stdin = "{{ hook_stdin }}"
        depends = "validate-release-tags"
      }
    }
  }
  ["post-checkout"] {
    steps {
      ["git-lfs"] {
        check = "git lfs post-checkout {{ hook_args }}"
      }
    }
  }
  ["post-merge"] {
    steps {
      ["git-lfs"] {
        check = "git lfs post-merge {{ hook_args }}"
      }
    }
  }
  ["post-commit"] {
    steps {
      ["git-lfs"] {
        check = "git lfs post-commit {{ hook_args }}"
      }
    }
  }
}
