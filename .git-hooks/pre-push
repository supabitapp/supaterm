#!/usr/bin/env bash

set -euo pipefail

updates="$(cat)"
PRE_PUSH_REMOTE="${1:-origin}" mise run --raw validate-pre-push <<<"$updates"

while IFS=' ' read -r local_ref _ remote_ref _; do
  [[ -z "${local_ref:-}" ]] && continue
  if [[ "$local_ref" != refs/tags/* && "$remote_ref" != refs/tags/* ]]; then
    make web-check
    make web-test
    make mac-test
    exit 0
  fi
done <<< "$updates"
