{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "supaterm-com",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-03-21",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "supaterm.com",
      "custom_domain": true,
    },
    {
      "pattern": "www.supaterm.com",
      "custom_domain": true,
    },
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "single-page-application",
  },
}
